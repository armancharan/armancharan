# Copy to .env.local and fill in. All optional for local dev:
# - with none set, the puzzle works and subscribers are written to .data/subscribers.json,
#   and Turnstile verification is skipped.

# Puzzle solve-token signing. MUST match worker/.dev.vars (and the Worker's
# `wrangler secret put PUZZLE_SECRET`) so tokens minted by the Durable Object
# verify on Vercel. Set a long random string in production.
PUZZLE_SECRET=

# Puzzle WebSocket endpoint (the Cloudflare Worker + Durable Object).
# Local: ws://localhost:8799/puzzle  ·  Prod: wss://<your-worker>.workers.dev/puzzle
NEXT_PUBLIC_PUZZLE_WS_URL=

# Cloudflare Turnstile (invisible bot backstop)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cloudflare D1 over HTTP (subscriber storage from Vercel)
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_API_TOKEN=
